/*
 * nucleo_l476rg.overlay — Mapa de pines
 *
 * NTC: PA0 = ADC1_IN5 (header Arduino "A0").
 * Elegido para no chocar con PA2/PA3 (USART2, usado por el ST-Link VCP / monitor
 * serial que ya probaste) ni con PB6/PB7 (I2C1, reservado para el OLED).
 *
 * IMPORTANTE — verificar contra tu cableado físico antes de confiar en lecturas:
 * Este overlay asume divisor de voltaje: VDD(3.3V) -- NTC -- [nodo ADC, PA0] -- R_fija(10k) -- GND
 * Si tu circuito tiene el NTC y la resistencia fija invertidos (R_fija arriba,
 * NTC abajo), la fórmula en ntc_sensor.c debe invertirse (ver TODO ahí).
 *
 * Ventilador: PA6 = TIM3_CH1 (header Arduino "D12"), frecuencia PWM 25kHz —
 * TODO: confirmar contra el datasheet de tu ventilador específico (2 vs 4 pines;
 * si es de 4 pines con línea PWM dedicada, 25kHz es estándar de la industria;
 * si controlas un motor DC simple vía MOSFET, la frecuencia es menos crítica
 * pero conviene mantenerla por encima del rango audible, >20kHz).
 */

#include <zephyr/dt-bindings/adc/adc.h>
#include <zephyr/dt-bindings/pinctrl/stm32-pinctrl.h>
#include <zephyr/dt-bindings/pwm/pwm.h>

/ {
	zephyr,user {
		io-channels = <&adc1 5>;
		pwms = <&pwm3 1 PWM_KHZ(25) PWM_POLARITY_NORMAL>;
	};
};

&adc1 {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";
	pinctrl-0 = <&adc1_in5_pa0>;
	pinctrl-names = "default";

	channel@5 {
		reg = <5>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_VDD_1";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};
};

&timers3 {
	status = "okay";

	pwm3: pwm {
		status = "okay";
		pinctrl-0 = <&tim3_ch1_pa6>;
		pinctrl-names = "default";
	};
};

&pinctrl {
	adc1_in5_pa0: adc1_in5_pa0 {
		pinmux = <STM32_PINMUX('A', 0, ANALOG)>;
	};

	tim3_ch1_pa6: tim3_ch1_pa6 {
		pinmux = <STM32_PINMUX('A', 6, AF2)>;
	};
};

