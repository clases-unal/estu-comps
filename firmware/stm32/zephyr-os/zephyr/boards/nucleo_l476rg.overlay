/*
 * nucleo_l476rg.overlay — Mapa de pines del sistema
 *
 * CÓMO CAMBIAR UN PIN:
 *   1. Elige el periférico STM32 que quieres usar (ej. TIM3, ADC1, USART1...)
 *   2. Consulta la tabla "Alternate function mapping" del datasheet STM32L476
 *      para saber qué AF number corresponde a ese periférico en el pin elegido.
 *   3. Crea o modifica la entrada en &pinctrl con STM32_PINMUX('Puerto', pin, AF).
 *   4. Aplica esa configuración al periférico correspondiente (&timers3, &adc1...).
 *   Para GPIO simples (LEDs, pulsador) no se necesita pinctrl.
 *
 * PINES ASIGNADOS:
 *   PA0  ANALOG  — ADC1 canal 5 — Lectura NTC
 *                  Circuito: VDD --[NTC]--> PA0 --[R10k]--> GND
 *   PA6  AF2     — TIM3_CH1    — PWM ventilador (D12 en header Arduino)
 *   PC13 GPIO    — Input       — Pulsador usuario (definido en DTS base)
 */

#include <zephyr/dt-bindings/adc/adc.h>
#include <zephyr/dt-bindings/pinctrl/stm32-pinctrl.h>
#include <zephyr/dt-bindings/pwm/pwm.h>

/ {
	zephyr,user {
		io-channels = <&adc1 5>;
		pwms = <&pwm3 1 PWM_KHZ(25) PWM_POLARITY_NORMAL>;
	};
};

/* ── PINCTRL: definición de configuraciones de pines ─────────────────────── */
&pinctrl {
	ntc_adc_pins: ntc_adc_pins {
		group1 {
			/* PA0 en modo ANALOG para ADC1_IN5.
			 * ANALOG no es una función alternativa numerada — desconecta
			 * el pin del GPIO digital y lo entrega directamente al ADC. */
			pinmux = <STM32_PINMUX('A', 0, ANALOG)>;
		};
	};

	fan_pwm_pins: fan_pwm_pins {
		group1 {
			/* PA6 con AF2 = TIM3_CH1 (salida PWM del ventilador).
			 * AF2 en PA6 es el único AF que activa TIM3_CH1 en este pin
			 * — verificado contra datasheet STM32L476, tabla pág. 89. */
			pinmux = <STM32_PINMUX('A', 6, AF2)>;
		};
	};
};

/* ── PERIFÉRICOS ─────────────────────────────────────────────────────────── */
&adc1 {
	status = "okay";
	pinctrl-0 = <&ntc_adc_pins>;
	pinctrl-names = "default";
	#address-cells = <1>;
	#size-cells = <0>;

	channel@5 {
		reg = <5>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};
};

&timers3 {
	status = "okay";

	pwm3: pwm {
		status = "okay";
		pinctrl-0 = <&fan_pwm_pins>;
		pinctrl-names = "default";
	};
};
