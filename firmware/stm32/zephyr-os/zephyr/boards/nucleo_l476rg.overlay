/*
 * nucleo_l476rg.overlay — Mapa de pines del hardware y configuración de periféricos.
 *
 * Este archivo es el punto central para decirle a Zephyr qué pines del STM32 se
 * usan para cada función del proyecto. Si cambia el hardware, aquí se cambian las
 * asociaciones entre funciones lógicas (sensor, ventilador, LEDs, botón, UART,
 * display) y pines físicos del microcontrolador.
 *
 * Cómo leer este archivo:
 * - La sección / { ... } define los recursos del sistema que el firmware consume
 *   desde el árbol de dispositivos.
 * - La sección &pinctrl define el modo eléctrico de algunos pines (ADC, PWM,
 *   I2C, etc.).
 * - Las secciones &adc1, &timers3, &usart1, &i2c1 hacen referencia a esos
 *   recursos y los habilitan para las funciones concretas del proyecto.
 *
 * Cómo cambiar un pin GPIO:
 * 1. Localice la definición del recurso que quiere mover (por ejemplo led0,
 *    heater_pin, row_0, col_0, etc.).
 * 2. Cambie la referencia del pin en la línea gpios = <&gpiob 0 GPIO_ACTIVE_HIGH>.
 *    La forma general es: <&gpioX Y Z> donde:
 *      - X = puerto del STM32 (a, b, c, ...)
 *      - Y = número de pin dentro del puerto
 *      - Z = nivel activo / polaridad
 * 3. Si el pin se usa también en el pinctrl o en un periférico (PWM, ADC, I2C,
 *    UART), verifique que el cambio sea compatible con esos modos.
 * 4. Si el cambio afecta a un periférico físico, ajuste también la lógica del
 *    driver en src/ que espera ese recurso.
 *
 * Ejemplo:
 * - Para mover el LED0 de PB0 a PA5, cambiaría:
 *     led0: led_0 { gpios = <&gpiob 0 GPIO_ACTIVE_HIGH>; };
 *   por:
 *     led0: led_0 { gpios = <&gpioa 5 GPIO_ACTIVE_HIGH>; };
 */

#include <zephyr/dt-bindings/adc/adc.h>
#include <zephyr/dt-bindings/pinctrl/stm32-pinctrl.h>
#include <zephyr/dt-bindings/pwm/pwm.h>
#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
	zephyr,user {
		io-channels = <&adc1 5>;
		pwms        = <&pwm3 1 PWM_KHZ(25) PWM_POLARITY_NORMAL>;
	};

	system_leds {
		compatible = "gpio-leds";
		led0: led_0 { gpios = <&gpiob 0  GPIO_ACTIVE_HIGH>; label = "LED0"; };
		led1: led_1 { gpios = <&gpiob 1  GPIO_ACTIVE_HIGH>; label = "LED1"; };
		led2: led_2 { gpios = <&gpiob 3  GPIO_ACTIVE_HIGH>; label = "LED2"; };
		led3: led_3 { gpios = <&gpiob 4  GPIO_ACTIVE_HIGH>; label = "LED3"; };
		led4: led_4 { gpios = <&gpiob 5  GPIO_ACTIVE_HIGH>; label = "LED4"; };
		led5: led_5 { gpios = <&gpiob 10 GPIO_ACTIVE_HIGH>; label = "LED5"; };
	};

	heater_ctrl {
		compatible = "gpio-leds";
		heater_pin: heater_0 { gpios = <&gpioa 8 GPIO_ACTIVE_HIGH>; label = "Heater sim"; };
	};

	/* Se reescribió este bloque para exponer cada pin del teclado como un nodo
	 * independiente con etiqueta, que es lo que el driver espera al usar
	 * DT_NODELABEL(row_0), DT_NODELABEL(col_0), etc.
	 *
	 * Mapeo físico actual:
	 * - Filas: PC0, PC1, PC2, PC3
	 * - Columnas: PC4, PC5, PC6, PC7
	 *
	 * Si cambias estos pines, actualiza solo este overlay.
	 * El código del driver ya consume los nodos DT y no requiere modificaciones.
	 */
	keypad_rows {
		compatible = "gpio-keys";
		row_0: row_0 { gpios = <&gpioc 0 GPIO_ACTIVE_LOW>; };
		row_1: row_1 { gpios = <&gpioc 1 GPIO_ACTIVE_LOW>; };
		row_2: row_2 { gpios = <&gpioc 2 GPIO_ACTIVE_LOW>; };
		row_3: row_3 { gpios = <&gpioc 3 GPIO_ACTIVE_LOW>; };
	};

	keypad_cols {
		compatible = "gpio-keys";
		col_0: col_0 { gpios = <&gpioc 4 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; };
		col_1: col_1 { gpios = <&gpioc 5 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; };
		col_2: col_2 { gpios = <&gpioc 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; };
		col_3: col_3 { gpios = <&gpioc 7 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; };
	};
};

/* ── SECCIÓN PINCTRL ────────────────────────────────────────────────────── */
&pinctrl {
	ntc_adc_pins: ntc_adc_pins {
		pinmux = <STM32_PINMUX('A', 0, ANALOG)>;
	};
	
	fan_pwm_pins: fan_pwm_pins {
		pinmux = <STM32_PINMUX('A', 6, AF2)>;
	};

	/* ¡NUEVO FORMATO!
	Cada pin de I2C es su propio nodo independiente */
	i2c1_scl_pb6: i2c1_scl_pb6 {
		pinmux = <STM32_PINMUX('B', 6, AF4)>;
		bias-pull-up;
		drive-open-drain;
	};
	
	i2c1_sda_pb7: i2c1_sda_pb7 {
		pinmux = <STM32_PINMUX('B', 7, AF4)>;
		bias-pull-up;
		drive-open-drain;
	};
};

/* ── PERIFÉRICOS ────────────────────────────────────────────────────────── */

&adc1 {
	pinctrl-0 = <&ntc_adc_pins>;
	#address-cells = <1>;
	#size-cells = <0>;

	channel@5 {
		reg = <5>;
		zephyr,gain             = "ADC_GAIN_1";
		zephyr,reference        = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution       = <12>;
	};
};

&timers3 {
	pwm3: pwm {
		pinctrl-0 = <&fan_pwm_pins>;
	};
};

&usart1 {
	/* UART1 se usa en este firmware para la comunicación con el ESP32.
	 * En la placa Nucleo-L476RG, USART1 está mapeado por defecto a PA9 (TX)
	 * y PA10 (RX). Si decides mover la conexión al ESP32, cambia estos pines
	 * aquí y asegúrate de que el dispositivo siga llamándose "usart1".
	 */
	pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
	pinctrl-names = "default";
	status = "okay";
};

&i2c1 {
	pinctrl-0 = <&i2c1_scl_pb6 &i2c1_sda_pb7>;
	status = "okay"; /* Asegura que el bus esté activo */
	
	ssd1306: ssd1306@3c {
		compatible        = "solomon,ssd1306fb";
		reg               = <0x3c>;
		width             = <128>;
		height            = <64>;
		segment-offset    = <0>;
		page-offset       = <0>;
		display-offset    = <0>;
		multiplex-ratio   = <63>;
		segment-remap;
		com-invdir;
		prechargep        = <0x22>;
		status            = "okay"; /* <-- AGREGA ESTA LÍNEA AQUÍ */
	};
};